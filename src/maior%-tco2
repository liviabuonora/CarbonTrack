import os
os.system("cls")

def calcular_percentual(valor, total):
    return (valor / total) * 100
 
def maior_fonte(fontes, valores):
    maior_valor = 0
    maior_nome = ""
 
    for i in range(len(fontes)):
        if valores[i] > maior_valor:
            maior_valor = valores[i]
            maior_nome = fontes[i]
 
    return maior_nome, maior_valor
 
def main():
    print("Emissões por fonte\n")
 
    quantidade = int(input("Digite quantas fontes deseja informar: "))
 
    fontes = []
    valores = []
 
    for i in range(quantidade):
        nome = input(f"\nNome da fonte {i + 1}: ")
        valor = float(input(f"Emissao da fonte {i + 1} (tCO2eq): "))
        fontes.append(nome)
        valores.append(valor)
 
    total = sum(valores)
 
    print("\nResultado")
    for i in range(len(fontes)):
        percentual = calcular_percentual(valores[i], total)
        print(f"{fontes[i]}: {valores[i]} tCO2eq ({percentual:.1f}%)")
 
    nome, valor = maior_fonte(fontes, valores)
    percentual_maior = calcular_percentual(valor, total)
 
    print(f"\nMaior fonte: {nome} com {percentual_maior:.1f}% do total.")
    print(f"Essa fonte precisa ser reduzida.")
 
main()